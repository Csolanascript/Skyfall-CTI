# --- MITRE Ingestor ---
RUN_MITRE_INGESTOR=0
# --- Neo4j client credentials ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skyfall2026
# ============================================================================
#  SKYFALL-CTI — Variables de entorno
#  Copia este archivo como .env y rellena los valores requeridos
# ============================================================================

# --- n8n (orquestación no-code) ---
# Clave de cifrado para credenciales guardadas dentro de n8n.
# ¡¡ Si la cambias, todas las credenciales almacenadas se pierden !!
# Genera una con:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=
# Usuario y contraseña del owner que se crea automáticamente
N8N_DEFAULT_USER_EMAIL=admin@skyfall.local
N8N_DEFAULT_USER_PASSWORD=

# --- Telegram Crawler (Telethon) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Intel-Owl ---
INTELOWL_API_KEY=
INTELOWL_DB_PASSWORD=intelowl
INTELOWL_DJANGO_SECRET=changeme_in_production

# --- Grok / xAI (n8n-osint) ---
GROK_API_KEY=

# --- Dumps Crawler (GitHub scraping) ---
GITHUB_TOKEN=

# --- KEVin / NVD ---
NVD_API_KEY=

# --- Neo4j ---
NEO4J_AUTH=neo4j/skyfall2026
NEO4J_ACCEPT_LICENSE_AGREEMENT=yes
NEO4J_PLUGINS='["apoc"]'
NEO4J_server_bolt_advertised__address=localhost:7687
NEO4J_server_bolt_listen__address=:7687
NEO4J_server_ssl_policy_bolt_enabled=false
NEO4J_server_config_strict__validation_enabled=false

# --- Seguridades de Elastic Stack ---
ELASTIC_PASSWORD=skyfall2026
KIBANA_PASSWORD=skyfall2026
ELASTICSEARCH_SERVICEACCOUNTTOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY= xxxxxxxxxxxxxxx
XPACK_SECURITY_ENCRYPTIONKEY= xxxxxxxxxxxxxxxxxxxxxxx
XPACK_REPORTING_ENCRYPTIONKEY= xxxxxxxxxxxxxxxxxxxxxxx


# ---Kafka
KAFKA_CLUSTER_ID=skyfall_cti_2026_kraft
